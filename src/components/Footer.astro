---
// Gedeelde footer met contactgegevens (placeholders).
const jaar = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-grid">
    <div>
      <h3>Kloosterman Houtbouw</h3>
      <p>Ambachtelijke houtbouw in Doezum en omstreken — Groningen &amp; Friesland.</p>
    </div>

    <div>
      <h3>Contact</h3>
      <ul class="footer-lijst">
        <li>Voorbeeldstraat 1, 9863 PA Doezum</li>
        <li><a href="tel:+31600000000">06 - 00 00 00 00</a></li>
        <li><a href="mailto:info@kloostermanhoutbouw.nl">info@kloostermanhoutbouw.nl</a></li>
      </ul>
    </div>

    <div>
      <h3>Pagina's</h3>
      <ul class="footer-lijst">
        <li><a href="/">Projecten</a></li>
        <li><a href="/info">Info</a></li>
        <li><a href="/verhuur">Materieel verhuur</a></li>
      </ul>
    </div>
  </div>

  <div class="footer-onder">
    <div class="container">
      <p>&copy; {jaar} Kloosterman Houtbouw · Doezum. Alle rechten voorbehouden.</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background-color: var(--kleur-hout-donker);
    color: var(--kleur-creme);
    margin-top: auto;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 2rem;
    padding-block: 3rem;
  }

  .site-footer h3 {
    color: var(--kleur-creme);
    margin-bottom: 0.75rem;
  }

  .site-footer p {
    color: rgba(244, 236, 224, 0.82);
  }

  .footer-lijst {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .footer-lijst li {
    margin-bottom: 0.4rem;
    color: rgba(244, 236, 224, 0.82);
  }

  .footer-lijst a {
    color: var(--kleur-creme);
  }

  .footer-lijst a:hover {
    color: var(--kleur-hout-licht);
  }

  .footer-onder {
    background-color: rgba(0, 0, 0, 0.18);
    padding-block: 1rem;
  }

  .footer-onder p {
    margin: 0;
    font-size: 0.85rem;
    color: rgba(244, 236, 224, 0.7);
    text-align: center;
  }
</style>
