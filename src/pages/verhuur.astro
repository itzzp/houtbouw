---
import Layout from '../layouts/Layout.astro';
import { materieel } from '../data/materieel';

const base = import.meta.env.BASE_URL;
---

<Layout titel="Materieel verhuur">
  <section class="sectie pagina-kop">
    <div class="container">
      <p class="kruimel">Materieel verhuur</p>
      <h1>Materieel te huur</h1>
      <p class="intro">
        Naast bouwen verhuren we ook een deel van ons materieel. Hieronder een overzicht.
        Er is geen online boekingssysteem — <strong>neem contact op om te huren</strong> en
        we vertellen je graag meer over beschikbaarheid en prijs.
      </p>
      <a href={`${base}info`} class="knop knop--licht-vol">Neem contact op om te huren</a>
    </div>
  </section>

  <section class="sectie">
    <div class="container">
      <div class="materieel-grid">
        {
          materieel.map((item) => (
            <article class="materieel-kaart">
              <div class="materieel-body">
                <h3>{item.naam}</h3>
                <p>{item.omschrijving}</p>
              </div>
              <div class="materieel-voet">
                <span class="prijs">
                  <span class="prijs-label">Prijs</span>
                  {item.prijs}
                </span>
                <a href={`${base}info`} class="huur-link">Neem contact op om te huren →</a>
              </div>
            </article>
          ))
        }
      </div>

      <p class="verhuur-noot">
        Prijzen en beschikbaarheid op aanvraag. Materieel wordt schoon en in goede staat
        verhuurd; we vragen je het zo terug te brengen.
      </p>
    </div>
  </section>
</Layout>

<style>
  .pagina-kop {
    background-color: var(--kleur-rood);
    color: var(--kleur-creme);
  }

  .pagina-kop h1 {
    color: var(--kleur-creme);
  }

  .pagina-kop .intro {
    color: rgba(244, 236, 224, 0.92);
  }

  .pagina-kop .intro strong {
    color: var(--kleur-creme);
  }

  .kruimel {
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--kleur-hout-licht);
    margin-bottom: 0.4rem;
  }

  .knop--licht-vol {
    background-color: var(--kleur-hout);
    border-color: var(--kleur-hout);
    color: var(--kleur-wit);
    margin-top: 1.5rem;
  }

  .knop--licht-vol:hover {
    background-color: var(--kleur-hout-licht);
    border-color: var(--kleur-hout-licht);
  }

  .materieel-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  .materieel-kaart {
    background-color: var(--kleur-wit);
    border: 1px solid var(--kleur-creme-donker);
    border-radius: var(--radius);
    box-shadow: var(--schaduw-zacht);
    display: flex;
    flex-direction: column;
    overflow: hidden;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .materieel-kaart:hover {
    transform: translateY(-3px);
    box-shadow: var(--schaduw);
  }

  .materieel-body {
    padding: 1.5rem 1.5rem 1rem;
    flex: 1;
  }

  .materieel-body h3 {
    margin-bottom: 0.4rem;
  }

  .materieel-body p {
    margin: 0;
    font-size: 0.95rem;
  }

  .materieel-voet {
    padding: 1rem 1.5rem;
    border-top: 1px solid var(--kleur-creme-donker);
    background-color: var(--kleur-creme);
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .prijs {
    font-family: var(--font-kop);
    font-weight: 700;
    color: var(--kleur-rood);
    font-size: 1.05rem;
  }

  .prijs-label {
    display: block;
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--kleur-tekst-zacht);
  }

  .huur-link {
    font-weight: 600;
    color: var(--kleur-hout-donker);
    font-size: 0.92rem;
  }

  .verhuur-noot {
    margin-top: 2rem;
    font-size: 0.9rem;
    font-style: italic;
    color: var(--kleur-tekst-zacht);
    text-align: center;
  }
</style>
