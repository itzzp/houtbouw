---
import Layout from '../layouts/Layout.astro';
import { materieel } from '../data/materieel';
import { euro } from '../scripts/verhuurStore';

const base = import.meta.env.BASE_URL;
---

<Layout titel="Materieel verhuur">
  <section class="sectie pagina-kop">
    <div class="container">
      <p class="kruimel">Materieel verhuur</p>
      <h1>Materieel te huur</h1>
      <p class="intro">
        Reserveer eenvoudig online. Kies een stuk materieel en een periode, dan zie je
        meteen of het beschikbaar is. Je aanvraag komt bij ons binnen en we bevestigen 'm.
      </p>
      <p class="demo-balk">
        🛠️ <strong>Demo:</strong> bij reserveren openen we een vooraf ingevulde e-mail naar ons,
        en de aanvraag verschijnt in het <a href={`${base}beheer`}>beheer</a>. (Met een
        Formspree-koppeling gaat verzenden vanzelf op de achtergrond.)
      </p>
    </div>
  </section>

  <!-- Reserveringsformulier -->
  <section class="sectie">
    <div class="container">
      <div class="reserveer-blok">
        <h2>Reserveer materieel</h2>
        <form id="reserveer-form" class="reserveer-form" novalidate>
          <div class="veld veld--breed">
            <label for="f-materieel">Materieel</label>
            <select id="f-materieel" required>
              <option value="" disabled selected>Kies materieel…</option>
              {
                materieel.map((m) => (
                  <option value={m.id} data-dagprijs={m.dagprijs}>
                    {m.naam} — {euro(m.dagprijs)}/dag
                  </option>
                ))
              }
            </select>
          </div>
          <div class="veld">
            <label for="f-start">Van</label>
            <input type="date" id="f-start" required />
          </div>
          <div class="veld">
            <label for="f-eind">Tot en met</label>
            <input type="date" id="f-eind" required />
          </div>
          <div class="veld">
            <label for="f-klant">Naam</label>
            <input type="text" id="f-klant" autocomplete="name" required />
          </div>
          <div class="veld">
            <label for="f-email">E-mail</label>
            <input type="email" id="f-email" autocomplete="email" required />
          </div>
          <div class="veld veld--breed reserveer-actie">
            <div id="prijs-indicatie" class="prijs-indicatie" hidden></div>
            <button type="submit" class="knop">Controleer &amp; reserveer</button>
          </div>
        </form>
        <p id="form-melding" class="form-melding" role="status" hidden></p>
      </div>
    </div>
  </section>

  <!-- Overzicht materieel met live beschikbaarheid -->
  <section class="sectie materieel-sectie">
    <div class="container">
      <h2>Ons materieel</h2>
      <div class="materieel-grid">
        {
          materieel.map((item) => (
            <article class="materieel-kaart" data-materieel={item.id}>
              <div class="materieel-body">
                <h3>{item.naam}</h3>
                <p>{item.omschrijving}</p>
                <div class="planning" data-planning={item.id}>
                  <span class="planning-laden">Planning laden…</span>
                </div>
              </div>
              <div class="materieel-voet">
                <span class="prijs">
                  <span class="prijs-label">Prijs per dag</span>
                  {euro(item.dagprijs)}
                </span>
                <button type="button" class="huur-knop" data-reserveer={item.id}>
                  Reserveer dit →
                </button>
              </div>
            </article>
          ))
        }
      </div>

      <p class="verhuur-noot">
        Prijzen zijn per dag, exclusief 21% btw. Materieel wordt schoon en in goede staat
        verhuurd; we vragen je het zo terug te brengen.
      </p>
    </div>
  </section>
</Layout>

<script>
  import {
    materieel,
    bezetteReserveringen,
    isBeschikbaar,
    voegReserveringToe,
    aantalDagen,
    periodeNL,
    weergaveStatus,
    STATUS_LABEL,
    euro,
    vandaagISO,
    BTW_TARIEF,
  } from '../scripts/verhuurStore';
  import { bedrijf } from '../data/bedrijf';

  const formspreeEndpoint = bedrijf.formspreeEndpoint;
  const bedrijfEmail = bedrijf.email;

  const $ = <T extends HTMLElement>(sel: string) => document.querySelector(sel) as T | null;

  const form = $<HTMLFormElement>('#reserveer-form');
  const selMat = $<HTMLSelectElement>('#f-materieel');
  const inStart = $<HTMLInputElement>('#f-start');
  const inEind = $<HTMLInputElement>('#f-eind');
  const inKlant = $<HTMLInputElement>('#f-klant');
  const inEmail = $<HTMLInputElement>('#f-email');
  const prijsInd = $<HTMLDivElement>('#prijs-indicatie');
  const melding = $<HTMLParagraphElement>('#form-melding');

  // Niet in het verleden kunnen kiezen.
  const vandaag = vandaagISO();
  if (inStart) inStart.min = vandaag;
  if (inEind) inEind.min = vandaag;

  function toonMelding(tekst: string, soort: 'ok' | 'fout') {
    if (!melding) return;
    melding.textContent = tekst;
    melding.className = `form-melding form-melding--${soort}`;
    melding.hidden = false;
  }

  function dagprijsVan(id: string): number {
    return materieel.find((m) => m.id === id)?.dagprijs ?? 0;
  }

  // Live prijsindicatie tijdens invullen.
  function ververPrijs() {
    if (!prijsInd || !selMat || !inStart || !inEind) return;
    const id = selMat.value;
    const s = inStart.value;
    const e = inEind.value;
    if (!id || !s || !e || e < s) {
      prijsInd.hidden = true;
      return;
    }
    const dagen = aantalDagen(s, e);
    const sub = dagen * dagprijsVan(id);
    const totaal = sub * (1 + BTW_TARIEF);
    const vrij = isBeschikbaar(id, s, e);
    prijsInd.hidden = false;
    prijsInd.innerHTML = vrij
      ? `<span class="ind-ok">✓ Beschikbaar</span> · ${dagen} dag(en) · ${euro(sub)} excl. btw · <strong>${euro(totaal)} incl. btw</strong>`
      : `<span class="ind-fout">✗ Niet beschikbaar in deze periode</span> — kies andere datums`;
  }

  [selMat, inStart, inEind].forEach((el) => el?.addEventListener('change', ververPrijs));

  // Planning per materieelstuk tonen.
  function tekenPlanning() {
    document.querySelectorAll<HTMLElement>('[data-planning]').forEach((box) => {
      const id = box.dataset.planning!;
      const items = bezetteReserveringen(id)
        .slice()
        .sort((a, b) => a.start.localeCompare(b.start));
      if (items.length === 0) {
        box.innerHTML = `<span class="vrij-nu">✓ Nu volledig beschikbaar</span>`;
        return;
      }
      const rijen = items
        .map((r) => {
          const st = weergaveStatus(r);
          return `<li><span class="stip stip--${st}"></span>${periodeNL(r.start, r.eind)} <em>(${STATUS_LABEL[st].toLowerCase()})</em></li>`;
        })
        .join('');
      box.innerHTML = `<p class="planning-kop">Gereserveerde periodes:</p><ul class="planning-lijst">${rijen}</ul>`;
    });
  }

  // "Reserveer dit" knoppen → formulier prefillen en ernaartoe scrollen.
  document.querySelectorAll<HTMLButtonElement>('[data-reserveer]').forEach((btn) => {
    btn.addEventListener('click', () => {
      if (selMat) selMat.value = btn.dataset.reserveer!;
      ververPrijs();
      $('#reserveer-form')?.scrollIntoView({ behavior: 'smooth', block: 'center' });
      inStart?.focus();
    });
  });

  // Verzenden.
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const id = selMat?.value ?? '';
    const s = inStart?.value ?? '';
    const eind = inEind?.value ?? '';
    const klant = inKlant?.value.trim() ?? '';
    const email = inEmail?.value.trim() ?? '';

    if (!id || !s || !eind || !klant || !email) {
      toonMelding('Vul alle velden in om te reserveren.', 'fout');
      return;
    }
    if (eind < s) {
      toonMelding('De einddatum ligt vóór de startdatum.', 'fout');
      return;
    }
    if (!isBeschikbaar(id, s, eind)) {
      toonMelding('Dit materieel is in de gekozen periode al gereserveerd. Kies andere datums.', 'fout');
      return;
    }

    voegReserveringToe({ materieelId: id, klant, email, start: s, eind });
    const naam = materieel.find((m) => m.id === id)?.naam ?? 'materieel';

    // De aanvraag écht versturen naar Kloosterman.
    verstuurAanvraag({ naam, klant, email, periode: periodeNL(s, eind), dagen: aantalDagen(s, eind) });

    toonMelding(
      `✓ Aanvraag ontvangen! Je reservering voor ${naam} (${periodeNL(s, eind)}) staat klaar en wacht op bevestiging. We nemen contact op via ${email}.`,
      'ok',
    );
    form.reset();
    prijsInd && (prijsInd.hidden = true);
    tekenPlanning();
  });

  // Stuurt de aanvraag naar de mailbox van Kloosterman.
  // Met Formspree-endpoint → echte verzending op de achtergrond.
  // Zonder endpoint → opent een vooraf ingevulde e-mail (mailto), zodat het
  // ook zonder configuratie meteen werkt.
  function verstuurAanvraag(g: {
    naam: string;
    klant: string;
    email: string;
    periode: string;
    dagen: number;
  }) {
    const onderwerp = `Reserveringsaanvraag: ${g.naam}`;
    const tekst =
      `Nieuwe reserveringsaanvraag via de website:\n\n` +
      `Materieel: ${g.naam}\n` +
      `Periode: ${g.periode} (${g.dagen} dag(en))\n` +
      `Naam: ${g.klant}\n` +
      `E-mail: ${g.email}\n`;

    if (formspreeEndpoint) {
      fetch(formspreeEndpoint, {
        method: 'POST',
        headers: { Accept: 'application/json', 'Content-Type': 'application/json' },
        body: JSON.stringify({
          _subject: onderwerp,
          materieel: g.naam,
          periode: g.periode,
          naam: g.klant,
          email: g.email,
        }),
      }).catch(() => {
        /* stil falen: de reservering staat al in de planning */
      });
    } else {
      // Fallback: open de mailclient met alles vooringevuld.
      const url = `mailto:${bedrijfEmail}?subject=${encodeURIComponent(onderwerp)}&body=${encodeURIComponent(tekst)}`;
      window.open(url, '_blank');
    }
  }

  tekenPlanning();
</script>

<style>
  .pagina-kop {
    background-color: var(--kleur-rood);
    color: var(--kleur-creme);
  }

  .pagina-kop h1 {
    color: var(--kleur-creme);
  }

  .pagina-kop .intro {
    color: rgba(244, 236, 224, 0.92);
  }

  .kruimel {
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--kleur-hout-licht);
    margin-bottom: 0.4rem;
  }

  .demo-balk {
    margin-top: 1.25rem;
    background-color: rgba(0, 0, 0, 0.18);
    border-radius: var(--radius);
    padding: 0.7rem 1rem;
    font-size: 0.92rem;
    color: var(--kleur-creme);
  }

  .demo-balk a {
    color: var(--kleur-creme);
    text-decoration: underline;
  }

  /* Reserveringsformulier */
  .reserveer-blok {
    background-color: var(--kleur-wit);
    border: 1px solid var(--kleur-creme-donker);
    border-radius: var(--radius);
    padding: 1.75rem;
    box-shadow: var(--schaduw-zacht);
  }

  .reserveer-blok h2 {
    margin-top: 0;
  }

  .reserveer-form {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .veld {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .veld--breed {
    grid-column: 1 / -1;
  }

  .veld label {
    font-family: var(--font-kop);
    font-weight: 600;
    font-size: 0.85rem;
    color: var(--kleur-rood);
  }

  .veld input,
  .veld select {
    font-family: inherit;
    font-size: 1rem;
    padding: 0.6rem 0.7rem;
    border: 1px solid var(--kleur-creme-donker);
    border-radius: 8px;
    background-color: var(--kleur-creme);
    color: var(--kleur-tekst);
  }

  .veld input:focus,
  .veld select:focus {
    outline: 2px solid var(--kleur-hout-licht);
    outline-offset: 1px;
  }

  .reserveer-actie {
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .prijs-indicatie {
    font-size: 0.95rem;
    color: var(--kleur-tekst-zacht);
  }

  .ind-ok {
    color: #2e7d32;
    font-weight: 700;
  }

  .ind-fout {
    color: var(--kleur-rood);
    font-weight: 700;
  }

  .form-melding {
    margin-top: 1rem;
    padding: 0.85rem 1rem;
    border-radius: var(--radius);
    font-size: 0.95rem;
  }

  .form-melding--ok {
    background-color: #e6f4ea;
    color: #1e5631;
    border: 1px solid #b6dcc0;
  }

  .form-melding--fout {
    background-color: #fdecea;
    color: #8a160f;
    border: 1px solid #f5c2bd;
  }

  /* Materieel-overzicht */
  .materieel-sectie {
    background-color: var(--kleur-creme-donker);
  }

  .materieel-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
    margin-top: 1.5rem;
  }

  .materieel-kaart {
    background-color: var(--kleur-wit);
    border: 1px solid var(--kleur-creme-donker);
    border-radius: var(--radius);
    box-shadow: var(--schaduw-zacht);
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .materieel-body {
    padding: 1.5rem 1.5rem 1rem;
    flex: 1;
  }

  .materieel-body h3 {
    margin-bottom: 0.4rem;
  }

  .materieel-body p {
    margin: 0 0 0.75rem;
    font-size: 0.95rem;
  }

  .planning {
    font-size: 0.85rem;
    border-top: 1px dashed var(--kleur-creme-donker);
    padding-top: 0.7rem;
  }

  .planning-laden,
  .vrij-nu {
    color: var(--kleur-tekst-zacht);
  }

  .vrij-nu {
    color: #2e7d32;
    font-weight: 600;
  }

  .planning-kop {
    margin: 0 0 0.35rem;
    font-weight: 600;
    color: var(--kleur-tekst);
  }

  .planning-lijst {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .planning-lijst li {
    color: var(--kleur-tekst-zacht);
  }

  .planning-lijst em {
    font-style: normal;
    opacity: 0.75;
  }

  .stip {
    display: inline-block;
    width: 9px;
    height: 9px;
    border-radius: 50%;
    margin-right: 0.45rem;
    background-color: var(--kleur-hout);
  }

  .stip--lopend { background-color: #e09f3e; }
  .stip--gereserveerd { background-color: var(--kleur-rood); }
  .stip--aangevraagd { background-color: #6c8ea4; }
  .stip--afgerond { background-color: #9aa0a6; }

  .materieel-voet {
    padding: 1rem 1.5rem;
    border-top: 1px solid var(--kleur-creme-donker);
    background-color: var(--kleur-creme);
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .prijs {
    font-family: var(--font-kop);
    font-weight: 700;
    color: var(--kleur-rood);
    font-size: 1.05rem;
  }

  .prijs-label {
    display: block;
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--kleur-tekst-zacht);
  }

  .huur-knop {
    font-family: var(--font-kop);
    font-weight: 600;
    font-size: 0.92rem;
    color: var(--kleur-wit);
    background-color: var(--kleur-hout);
    border: none;
    border-radius: 8px;
    padding: 0.55rem 0.8rem;
    cursor: pointer;
    transition: background-color 0.2s ease;
  }

  .huur-knop:hover {
    background-color: var(--kleur-hout-donker);
  }

  .verhuur-noot {
    margin-top: 2rem;
    font-size: 0.9rem;
    font-style: italic;
    color: var(--kleur-tekst-zacht);
    text-align: center;
  }

  @media (max-width: 560px) {
    .reserveer-form {
      grid-template-columns: 1fr;
    }
  }
</style>
