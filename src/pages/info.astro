---
import Layout from '../layouts/Layout.astro';

const specialisaties = [
  {
    titel: 'Houtskeletbouw',
    tekst: 'Complete woningen en uitbouwen in houtskeletbouw — duurzaam, goed geïsoleerd en snel wind- en waterdicht.',
  },
  {
    titel: 'Verbouw & renovatie',
    tekst: 'Dakkapellen, aanbouwen en renovaties, netjes afgewerkt en met oog voor detail.',
  },
  {
    titel: 'Bijgebouwen',
    tekst: 'Schuren, tuinkantoren, bergingen en overkappingen, volledig op maat gemaakt.',
  },
  {
    titel: 'Buitenleven',
    tekst: "Veranda's, terrasoverkappingen en houten constructies die je tuin afmaken.",
  },
];
---

<Layout titel="Info">
  <section class="sectie pagina-kop">
    <div class="container">
      <p class="kruimel">Over ons</p>
      <h1>Vakmanschap in hout, uit Doezum</h1>
      <p class="intro">
        Kloosterman bouw en houtbewerking is een ambachtelijk bouw- en houtbewerkingsbedrijf
        uit Doezum. We bouwen met passie voor het materiaal en oog voor wat de klant écht nodig heeft.
      </p>
    </div>
  </section>

  <section class="sectie">
    <div class="container twee-kolom">
      <div>
        <h2>Ons verhaal</h2>
        <p>
          Hout zit ons in het bloed. Wat begon als een liefde voor het werken met hout, is
          uitgegroeid tot een bedrijf dat staat voor degelijk vakwerk en eerlijke afspraken.
          Of het nu gaat om een complete houtskeletbouw woning of een veranda achter het huis —
          we bouwen het met dezelfde zorg.
        </p>
        <p>
          We werken graag persoonlijk en betrokken. Korte lijnen, meedenken met de klant en een
          resultaat waar we allebei trots op zijn. Dat is waar Kloosterman bouw en houtbewerking
          voor staat.
        </p>

        <h2>Werkgebied</h2>
        <p>
          We zijn gevestigd in Doezum en werken in de wijde omgeving: heel Groningen en Friesland.
          Twijfel je of jouw locatie binnen ons werkgebied valt? Neem gerust contact op, dan
          kijken we wat mogelijk is.
        </p>
      </div>

      <aside class="contact-blok">
        <h2>Contactgegevens</h2>
        <ul class="contact-lijst">
          <li>
            <span class="label">Adres</span>
            <span>Provincialeweg 127<br />9863 PE Doezum</span>
          </li>
          <li>
            <span class="label">Telefoon</span>
            <a href="tel:+31652090713">06 - 52 09 07 13</a>
          </li>
          <li>
            <span class="label">E-mail</span>
            <a href="mailto:info@kloostermanbouw.nl">info@kloostermanbouw.nl</a>
          </li>
          <li>
            <span class="label">Werkgebied</span>
            <span>Doezum &amp; omstreken · Groningen en Friesland</span>
          </li>
          <li>
            <span class="label">Bedrijfsgegevens</span>
            <span>KvK 01159062<br />BTW NL003177242B10</span>
          </li>
        </ul>
      </aside>
    </div>
  </section>

  <section class="sectie specialisaties">
    <div class="container">
      <h2 class="tekst-midden">Onze specialisaties</h2>
      <div class="spec-grid">
        {
          specialisaties.map((s) => (
            <div class="spec-kaart">
              <h3>{s.titel}</h3>
              <p>{s.tekst}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>
</Layout>

<style>
  .pagina-kop {
    background-color: var(--kleur-rood);
    color: var(--kleur-creme);
  }

  .pagina-kop h1 {
    color: var(--kleur-creme);
  }

  .pagina-kop .intro {
    color: rgba(244, 236, 224, 0.92);
  }

  .kruimel {
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--kleur-hout-licht);
    margin-bottom: 0.4rem;
  }

  .twee-kolom {
    display: grid;
    grid-template-columns: 1.6fr 1fr;
    gap: 2.5rem;
    align-items: start;
  }

  .contact-blok {
    background-color: var(--kleur-wit);
    border: 1px solid var(--kleur-creme-donker);
    border-radius: var(--radius);
    padding: 1.75rem;
    box-shadow: var(--schaduw-zacht);
    position: sticky;
    top: 90px;
  }

  .contact-blok h2 {
    font-size: 1.4rem;
    margin-bottom: 1rem;
  }

  .contact-lijst {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .contact-lijst li {
    display: flex;
    flex-direction: column;
    padding-block: 0.7rem;
    border-bottom: 1px solid var(--kleur-creme-donker);
  }

  .contact-lijst li:last-child {
    border-bottom: none;
  }

  .label {
    font-family: var(--font-kop);
    font-weight: 600;
    color: var(--kleur-rood);
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-bottom: 0.15rem;
  }

  .specialisaties {
    background-color: var(--kleur-creme-donker);
  }

  .spec-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1.25rem;
    margin-top: 2rem;
  }

  .spec-kaart {
    background-color: var(--kleur-wit);
    border-radius: var(--radius);
    padding: 1.5rem;
    box-shadow: var(--schaduw-zacht);
    border-top: 4px solid var(--kleur-hout);
  }

  .spec-kaart p {
    margin: 0;
    font-size: 0.95rem;
  }

  @media (max-width: 720px) {
    .twee-kolom {
      grid-template-columns: 1fr;
    }

    .contact-blok {
      position: static;
    }
  }
</style>
