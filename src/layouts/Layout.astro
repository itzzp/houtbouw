---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  titel: string;
  beschrijving?: string;
}

const {
  titel,
  beschrijving = 'Kloosterman Houtbouw uit Doezum — ambachtelijke houtbouw, projecten en materieel verhuur in Groningen en Friesland.',
} = Astro.props;
---

<!doctype html>
<html lang="nl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={beschrijving} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Lettertypen: karaktervolle serif voor koppen, rustige sans voor body -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bitter:wght@500;600;700&family=Source+Sans+3:wght@400;600&display=swap"
      rel="stylesheet"
    />

    <title>{titel} · Kloosterman Houtbouw</title>
  </head>
  <body>
    <a href="#hoofd" class="visueel-verborgen">Naar inhoud springen</a>
    <Nav />
    <main id="hoofd">
      <slot />
    </main>
    <Footer />
  </body>
</html>

<style>
  html,
  body {
    height: 100%;
  }

  body {
    display: flex;
    flex-direction: column;
    min-height: 100vh;
  }

  main {
    flex: 1 0 auto;
  }
</style>
